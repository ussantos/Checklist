# Segurança Django
DJANGO_SECRET_KEY=troque-esta-chave-por-uma-chave-longa-e-aleatoria
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,IP_DO_SERVIDOR
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://IP_DO_SERVIDOR:8000

# Bind interno. Para expor apenas na máquina local, mantenha 127.0.0.1:8000.
# Para acesso pela rede/VPN, use 0.0.0.0:8000 e proteja com firewall.
APP_BIND=127.0.0.1:8000

# PostgreSQL
POSTGRES_DB=myrobot_checklist
POSTGRES_USER=myrobot
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Grafana interno. Mantenha o bind local ou proteja com VPN/firewall.
GRAFANA_BIND=127.0.0.1:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=troque-esta-senha-grafana

# Administrador inicial técnico.
# Após o primeiro acesso, use checklistadmin para cadastrar administradores nominais
# e usuários operacionais. Depois, troque esta senha no sistema.
INITIAL_CHECKLISTADMIN_PASSWORD=Trocar@Senha2026

# Senhas temporárias de usuários criados/redefinidos por administradores.
# Em produção, recomenda-se True. Para testes locais, o padrão é False.
FORCE_PASSWORD_CHANGE_ON_FIRST_LOGIN=False

# Upload de evidências
MAX_EVIDENCE_FILE_SIZE_MB=5

# Backup via rclone. Configure com: rclone config
# Exemplos de remoto: gdrive:MyRobotBackups ou onedrive:MyRobotBackups
RCLONE_REMOTE=gdrive:MyRobotBackups
BACKUP_RETENTION_DAYS=30

